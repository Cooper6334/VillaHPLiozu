---
// 社群品牌 icon 連結（LINE / Facebook / Instagram），用於頁尾。
import { getContent } from '../data/content';
import Icon from './Icon.astro';
const { site, ui } = getContent(Astro.currentLocale);
---

<div class="social-icons">
  <a href={site.lineUrl} target="_blank" rel="noopener" aria-label={ui.lineShort}><Icon name="line" /></a>
  <a href={site.facebook} target="_blank" rel="noopener" aria-label={ui.facebookText}><Icon name="facebook" /></a>
  <a href={site.instagram} target="_blank" rel="noopener" aria-label={ui.instagramText}><Icon name="instagram" /></a>
</div>

<style>
  .social-icons {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin: 0.4rem 0;
  }
  .social-icons a {
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-line);
    border-radius: 50%;
    color: var(--color-text);
    transition: background 0.3s, color 0.3s, border-color 0.3s;
  }
  .social-icons a:hover {
    background: var(--color-dark);
    border-color: var(--color-dark);
    color: #fff;
  }
  .social-icons :global(svg) { width: 18px; height: 18px; }
</style>
