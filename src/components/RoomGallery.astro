---
// 房型照片輪播：主圖 + 下方縮圖（縮圖取代點點，並標示目前照片）。
import { getContent } from '../data/content';

interface Props {
  images: string[];
  alt: string;
}
const { images, alt } = Astro.props;
const { ui } = getContent(Astro.currentLocale);
const multiple = images.length > 1;
---

<div class="room-gallery">
  <div class="gallery-main">
    {images.map((src, i) => (
      <img src={src} alt={alt} class:list={['gallery-img', { active: i === 0 }]} loading="lazy" />
    ))}
    {multiple && (
      <>
        <button class="gallery-arrow prev" type="button" aria-label={ui.prevLabel}>{ui.prevIcon}</button>
        <button class="gallery-arrow next" type="button" aria-label={ui.nextLabel}>{ui.nextIcon}</button>
      </>
    )}
  </div>

  {multiple && (
    <div class="gallery-thumbs">
      {images.map((src, i) => (
        <button
          class:list={['thumb', { active: i === 0 }]}
          type="button"
          aria-label={ui.slideLabel.replace('{n}', String(i + 1))}
        >
          <img src={src} alt="" loading="lazy" />
        </button>
      ))}
    </div>
  )}
</div>

<style>
  .gallery-main {
    position: relative;
    aspect-ratio: 1280 / 960;   /* 原圖框 4:3 */
    overflow: hidden;
    background: var(--color-bg);  /* 小圖留白處＝網站背景色 */
  }
  .gallery-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: scale-down;     /* 較小的圖置中、不放大、不裁切 */
    object-position: center;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .gallery-img.active { opacity: 1; }

  .gallery-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 42px;
    height: 42px;
    border: none;
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.3s;
  }
  .gallery-arrow:hover { background: rgba(0, 0, 0, 0.7); }
  .gallery-arrow.prev { left: 0; }
  .gallery-arrow.next { right: 0; }

  .gallery-thumbs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;   /* 縮圖列左右置中 */
    gap: 8px;
    margin-top: 8px;
  }
  .thumb {
    height: 64px;
    aspect-ratio: 1280 / 720;  /* 縮圖統一 16:9 */
    width: auto;
    padding: 0;
    border: none;
    cursor: pointer;
    background: none;
    overflow: hidden;
    opacity: 0.5;
    transition: opacity 0.3s, outline-color 0.3s;
    outline: 2px solid transparent;
    outline-offset: -2px;
    line-height: 0;
  }
  .thumb img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }
  .thumb:hover { opacity: 0.85; }
  .thumb.active { opacity: 1; outline-color: var(--color-dark); }

  @media (max-width: 820px) {
    .gallery-thumbs { gap: 6px; }
    .thumb { height: 52px; }
  }
</style>

<script>
  // 每個房型輪播獨立運作；主圖切換時同步高亮對應縮圖。
  document.querySelectorAll<HTMLElement>('.room-gallery').forEach((gallery) => {
    const imgs = Array.from(gallery.querySelectorAll<HTMLElement>('.gallery-img'));
    const thumbs = Array.from(gallery.querySelectorAll<HTMLElement>('.thumb'));
    if (imgs.length < 2) return;
    let cur = 0;

    const show = (i: number) => {
      cur = (i + imgs.length) % imgs.length;
      imgs.forEach((im, n) => im.classList.toggle('active', n === cur));
      thumbs.forEach((t, n) => t.classList.toggle('active', n === cur));
    };

    gallery.querySelector('.gallery-arrow.prev')?.addEventListener('click', () => show(cur - 1));
    gallery.querySelector('.gallery-arrow.next')?.addEventListener('click', () => show(cur + 1));
    thumbs.forEach((t, i) => t.addEventListener('click', () => show(i)));
  });
</script>
