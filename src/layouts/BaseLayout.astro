---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SideSocial from '../components/SideSocial.astro';
import { getContent, getLang } from '../data/content';

interface Props {
  title?: string;
  description?: string;
}
const lang = Astro.currentLocale;
const c = getContent(lang);
const { site, ui } = c;
const isEn = getLang(lang) === 'en';
const htmlLang = isEn ? 'en' : 'zh-Hant';
const { title, description = site.description } = Astro.props;
const sep = ui.titleSeparator;
const fullTitle = title ? `${title}${sep}${site.name}` : `${site.name}${sep}${site.slogan}`;

// ===== canonical 與多語 hreflang =====
// 由目前網址推回「無語言前綴」的基準路徑，再組出中／英兩個版本的絕對網址。
const path = Astro.url.pathname;
const basePath = (isEn ? path.replace(/^\/en/, '') : path) || '/';
const zhHref = basePath;
const enHref = basePath === '/' ? '/en/' : '/en' + basePath;
const canonicalUrl = new URL(path, Astro.site).href;
const zhUrl = new URL(zhHref, Astro.site).href;
const enUrl = new URL(enHref, Astro.site).href;
const ogImageUrl = new URL(site.ogImage ?? '/images/house.jpg', Astro.site).href;

// ===== JSON-LD 結構化資料（民宿，強化在地搜尋）=====
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BedAndBreakfast',
  name: site.name,
  alternateName: site.alternateName,
  description: site.description,
  url: Astro.site?.href,
  image: ogImageUrl,
  logo: new URL(site.logo, Astro.site).href,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address,
    addressLocality: site.addressLocality,
    addressRegion: site.addressRegion,
    postalCode: site.postalCode,
    addressCountry: 'TW',
  },
  geo: site.geo && {
    '@type': 'GeoCoordinates',
    latitude: site.geo.lat,
    longitude: site.geo.lng,
  },
  hasMap: site.mapUrl,
  petsAllowed: true,
  numberOfRooms: 7,
  sameAs: [site.facebook, site.instagram, site.lineUrl, site.bookingUrl].filter(Boolean),
  amenityFeature: (c.home?.features ?? []).map((f) => ({
    '@type': 'LocationFeatureSpecification',
    name: f.title,
    value: true,
  })),
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- canonical 與多語替代版本 -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="zh-Hant" href={zhUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={zhUrl} />

    <!-- Open Graph（社群分享用） -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={site.name} />
    <meta property="og:locale" content={isEn ? 'en_US' : 'zh_TW'} />
    <meta property="og:locale:alternate" content={isEn ? 'zh_TW' : 'en_US'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- 結構化資料 -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Fonts：Cormorant Unicase（英文標題）+ 思源黑體（中文內文） -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Unicase:wght@400;500;700&family=Noto+Sans+TC:wght@300;400;500;700&family=Noto+Serif+TC:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <SideSocial />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
