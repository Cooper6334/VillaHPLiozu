---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SideSocial from '../components/SideSocial.astro';
import { getContent, getLang } from '../data/content';

interface Props {
  title?: string;
  description?: string;
}
const lang = Astro.currentLocale;
const { site, ui } = getContent(lang);
const htmlLang = getLang(lang) === 'en' ? 'en' : 'zh-Hant';
const { title, description = site.description } = Astro.props;
const sep = ui.titleSeparator;
const fullTitle = title ? `${title}${sep}${site.name}` : `${site.name}${sep}${site.slogan}`;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph（社群分享用） -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Google Fonts：Cormorant Unicase（英文標題）+ 思源黑體（中文內文） -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Unicase:wght@400;500;700&family=Noto+Sans+TC:wght@300;400;500;700&family=Noto+Serif+TC:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <SideSocial />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
