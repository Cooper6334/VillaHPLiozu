---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingForm from '../components/BookingForm.astro';
import { getContent } from '../data/content';

const c = getContent(Astro.currentLocale);
const { site } = c;
const contactContent = c.contact;
const { intro, buttonText, infoLabels, facebookText, instagramText, formHint } = contactContent;
const f = contactContent.form;
// 點地址可開啟物件的 Google Map（連結存在 site.mapUrl）
const mapsUrl = site.mapUrl;
// site.googleFormUrl 有填才顯示自製表單；否則顯示提示
const hasForm = site.googleFormUrl.trim().length > 0;
---

<BaseLayout title={intro.heading} description={c.seo.contact}>
  <section class="page-intro">
    <p class="eyebrow">{intro.eyebrow}</p>
    <h2>{intro.heading}</h2>
    <div class="line"></div>
    <p class="muted">{intro.subheading}</p>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container contact-grid">
      <!-- 聯絡方式 -->
      <div class="contact-info">
        <div class="info-list">
          <div class="info-row"><span>{infoLabels.line}</span><a href={site.lineUrl} target="_blank" rel="noopener">{site.lineId}</a></div>
          <div class="info-row"><span>{infoLabels.instagram}</span><a href={site.instagram} target="_blank" rel="noopener">{instagramText}</a></div>
          <div class="info-row"><span>{infoLabels.facebook}</span><a href={site.facebook} target="_blank" rel="noopener">{facebookText}</a></div>
          <div class="info-row"><span>{infoLabels.address}</span><a href={mapsUrl} target="_blank" rel="noopener">{site.address}</a></div>
        </div>
        <a href={site.lineUrl} target="_blank" rel="noopener" class="btn contact-btn">{buttonText}</a>
      </div>

      <!-- 訂房諮詢表單 -->
      <div class="contact-form">
        {hasForm ? (
          <>
            <h3 class="form-heading">{f.heading}</h3>
            <BookingForm />
          </>
        ) : (
          <p class="muted form-hint">{formHint}</p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    max-width: 720px;
    margin-inline: auto;
  }

  .info-list { border-top: 1px solid var(--color-muted); }
  .info-row {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    line-height: 3.4;
    border-bottom: 1px solid var(--color-line);
  }
  .info-row span:first-child {
    width: 90px;
    letter-spacing: 3px;
    color: var(--color-muted);
    font-size: 0.85rem;
  }
  .info-row a:hover { text-decoration: underline; }
  .contact-btn { display: block; text-align: center; margin-top: 2rem; }

  /* 訂房諮詢方塊（底色卡片）*/
  .contact-form {
    background: #f5f3ef;
    border: 1px solid var(--color-line);
    padding: 2.5rem;
  }
  .form-heading {
    font-size: 1.2rem;
    letter-spacing: 4px;
    margin-bottom: 1.8rem;
    color: var(--color-primary, var(--color-dark));
  }
  .form-hint { font-size: 0.85rem; line-height: 2; }

  @media (max-width: 820px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  @media (max-width: 600px) {
    .contact-form { padding: 1.5rem; }
  }
</style>
