---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent } from '../data/content';

const c = getContent(Astro.currentLocale);
const { site, ui } = c;
const bookingContent = c.booking;
const { intro, methodTitle, qrAlt, steps, noticeTitle, notes, disclaimer } = bookingContent;
---

<BaseLayout title={intro.heading}>
  <section class="page-intro">
    <p class="eyebrow">{intro.eyebrow}</p>
    <h2>{intro.heading}</h2>
    <div class="line"></div>
    <p class="muted">{intro.subheading}</p>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container container-narrow">
      <div class="regu-box">
        <div class="regu-title">{methodTitle}</div>
        <div class="method-body">
          <ol class="steps">
            {steps.map((s) => <li>{s}</li>)}
          </ol>
          <div class="qr-block">
            <a href={site.lineUrl} target="_blank" rel="noopener" class="qr-link">
              <img src={site.lineQr} alt={qrAlt} class="qr-img" />
            </a>
            <a href={site.lineUrl} target="_blank" rel="noopener" class="btn">{ui.lineShort} {site.lineId}</a>
          </div>
        </div>
      </div>

      <div class="regu-box">
        <div class="regu-title">{noticeTitle}</div>
        <dl class="notes">
          {notes.map((n) => (
            <div class="note-row"><dt>{n.label}</dt><dd>{n.desc}</dd></div>
          ))}
        </dl>
        <p class="muted small">{disclaimer}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .regu-box { border-top: 1px solid var(--color-muted); margin-bottom: 4rem; }
  .regu-title {
    width: 180px;
    height: 46px;
    line-height: 46px;
    text-align: center;
    letter-spacing: 6px;
    border-bottom: 1px solid var(--color-muted);
    margin-top: -1px;
    font-family: var(--font-serif);
  }
  .method-body {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    justify-content: space-between;
    padding-bottom: 2.5rem;
  }
  .steps { flex: 1; padding: 2.5rem 0 0 2.5rem; line-height: 2.4; letter-spacing: 1px; }
  .steps li { margin-bottom: 0.5rem; }
  .qr-block {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2.5rem 1rem 0 0;
  }
  .qr-link { display: block; margin-bottom: 1rem; transition: opacity 0.3s; }
  .qr-link:hover { opacity: 0.7; }
  .qr-img { width: 240px; height: auto; display: block; }

  @media (max-width: 600px) {
    .method-body { flex-direction: column; align-items: center; gap: 1rem; }
    .steps { padding: 2.5rem 1rem 0; }
    .qr-block { padding: 0 1rem; }
  }

  .notes { padding: 2.5rem 1rem; margin: 0; }
  .note-row { display: flex; gap: 2rem; padding: 0.9rem 0; border-bottom: 1px solid var(--color-line); }
  .note-row:last-child { border-bottom: none; }
  .note-row dt { min-width: 120px; letter-spacing: 3px; color: var(--color-muted); margin: 0; }
  .note-row dd { margin: 0; }
  .small { padding: 0 1rem; font-size: 0.8rem; }

  @media (max-width: 600px) {
    .note-row { flex-direction: column; gap: 0.3rem; }
  }
</style>
